# =============================================================================
# SOURCE DATABASE CONFIGURATION (Your existing investment data)
# =============================================================================
SOURCE_DB_TYPE=postgresql  # postgresql, sqlserver, mysql
SOURCE_DB_HOST=localhost
SOURCE_DB_PORT=5433  # Puerto diferente para evitar conflicto con analytics DB
SOURCE_DB_NAME=InvestmentData
SOURCE_DB_USER=your_username
SOURCE_DB_PASSWORD=your_password

# =============================================================================
# ANALYTICS DATABASE CONFIGURATION (usando tu contenedor postgres-learn)
# =============================================================================
ANALYTICS_DB_HOST=localhost
ANALYTICS_DB_PORT=5432
ANALYTICS_DB_NAME=learning
ANALYTICS_DB_USER=admin
ANALYTICS_DB_PASSWORD=password123

# =============================================================================
# APPLICATION SECURITY
# =============================================================================
SECRET_KEY=your-super-secret-key-change-this-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
ALGORITHM=HS256

# =============================================================================
# API CONFIGURATION
# =============================================================================
API_PREFIX=/api/v1
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8080"]
DEBUG=True
ENVIRONMENT=development

# =============================================================================
# POWER BI INTEGRATION
# =============================================================================
POWERBI_CLIENT_ID=your-powerbi-client-id
POWERBI_CLIENT_SECRET=your-powerbi-client-secret
POWERBI_TENANT_ID=your-azure-tenant-id
POWERBI_USERNAME=your-powerbi-username
POWERBI_PASSWORD=your-powerbi-password

# =============================================================================
# GOOGLE DATA STUDIO INTEGRATION
# =============================================================================
GOOGLE_SERVICE_ACCOUNT_FILE=path/to/service-account.json
GOOGLE_PROJECT_ID=your-google-project-id

# =============================================================================
# OPENAI CONFIGURATION (for AI analysis)
# =============================================================================
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4
OPENAI_MAX_TOKENS=4000

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
LOG_MAX_SIZE=10485760
LOG_BACKUP_COUNT=5

# =============================================================================
# ANALYSIS CONFIGURATION
# =============================================================================
# Maximum records to analyze at once
MAX_ANALYSIS_RECORDS=10000
# Cache TTL in seconds (1 hour)
CACHE_TTL=3600
# Analysis refresh interval in minutes
ANALYSIS_REFRESH_INTERVAL=15

# =============================================================================
# EXPORT CONFIGURATION
# =============================================================================
EXPORT_PATH=exports/
REPORT_TEMPLATE_PATH=templates/
CHART_OUTPUT_FORMAT=png
CHART_DPI=300

# =============================================================================
# PERFORMANCE SETTINGS  
# =============================================================================
CONNECTION_POOL_SIZE=20
CONNECTION_POOL_OVERFLOW=10
CONNECTION_POOL_TIMEOUT=30